<!-- 
================================================================================
MISSION SEQUENCE CONFIGURATION (XML)
================================================================================
USE THIS FILE FOR: Defining the mission flow, target depths, and approach distances.
NOTE: If you change this file, you MUST RESTART the Behavior Tree node to reload.
================================================================================
-->

<root BTCPP_format="4" main_tree_to_execute="PreQualification_Task">

    <BehaviorTree ID="PreQualification_Task">
        <Sequence name="main_mission">
            <!-- 0. SYSTEMS CHECK -->
            <!-- NOTE: Change timeout_s here to give sensors more time to come online -->
            <AllSystemsOK name="check_systems" timeout_s="20.0"/>

            <!-- 1. INITIALIZE -->
            <!-- NOTE: Change target_depth here (meters, positive-down) for the initial dive -->
            <DiveToDepth target_depth="1.7"/>

            <!-- 2. GATE MISSION -->
            
            <SurgeForwardDistance distance="2.0"/>


            <!-- NOTE: Change 'threshold' here to set how close to get to the gate before passing -->
            <!-- <ApproachObject object="GATE" threshold="1.0"/> -->
            
            <!-- NOTE: Surge through and clear the gate (Uses frame-counting in C++) -->
            <!-- <DriveThruGate/> -->

            <!-- 3. POLE MISSION -->
        
            <!-- <Exploration target_object="POLE" grace_duration="15.0"/> -->

            
            <!-- NOTE: Change 'threshold' here to set the radius of the orbit approach -->

            <SurgeForwardDistance distance="5.0"/>
            <StayStill duration="2.0"/>

            <SurgeForwardDistance distance="4.0"/>
            <StayStill duration="2.0"/>
            <!-- <ApproachObject object="POLE" threshold="1.0"/> -->

            <!-- NOTE: 5-leg square orbit. Pauses 3s at threshold, then X, 2X, 2X, 2X, X surges.
                 Surge duration X is orbit_surge_duration in mission_params.yaml. -->
            <OrbitPole object="POLE" staystill="3.0"/>
            <!-- <SurgeForwardDistance distance="8.0"/> -->
            <SurgeForwardDistance distance="5.0"/>
            <StayStill duration="2.0"/>
            <SurgeForwardDistance distance="4.0"/>
            <StayStill duration="2.0"/>
            
            <SurgeForwardDistance distance="2.0"/>

            <!-- <Exploration target_object="GATE" grace_duration="15.0"/> -->
            <!-- 4. RETURN HOME (Reactive) -->
            <!-- <Fallback name="find_gate_home">
                <IsObjectSeen object="GATE"/>
                <Exploration target_object="GATE" grace_duration="15.0"/>
                <Do360Turn success_when_seen="GATE"/>
            </Fallback> -->

            <!-- NOTE: Approach home gate to threshold -->
            <!-- <ApproachObject object="GATE" threshold="1.0"/> -->

            <!-- NOTE: Clear home gate -->
            <!-- <DriveThruGate/> -->
        </Sequence>
    </BehaviorTree>

    <TreeNodesModel>
        <Action ID="AllSystemsOK">
            <input_port name="timeout_s" type="double" default="20.0">Seconds to wait before aborting</input_port>
        </Action>
        <Condition ID="IsObjectSeen">
            <input_port name="object" type="std::string">GATE or POLE</input_port>
        </Condition>
        <Action ID="DiveToDepth">
            <input_port name="target_depth" type="double">Depth to dive to</input_port>
        </Action>
        <Action ID="Do360Turn">
            <input_port name="success_when_seen" type="std::string">Stop when this is seen</input_port>
        </Action>
        <Action ID="ApproachObject">
            <input_port name="object" type="std::string">Object to approach</input_port>
            <input_port name="threshold" type="double">Target distance</input_port>
        </Action>
        <Action ID="DriveThruGate"/>
        <Action ID="Exploration">
            <input_port name="target_object" type="std::string">Object to search for: GATE or POLE</input_port>
            <input_port name="grace_duration" type="double" default="15.0">Seconds to surge after a wrong detection before FAILURE</input_port>
        </Action>
        <Action ID="StayStill">
            <input_port name="duration" type="double" default="3.0">Seconds to hold position</input_port>
        </Action>
        <Action ID="OrbitPole">
            <input_port name="object" type="std::string">Object to orbit</input_port>
            <input_port name="staystill" type="double" default="0.0">Seconds to pause at threshold before orbiting</input_port>
        </Action>
    </TreeNodesModel>

</root>
