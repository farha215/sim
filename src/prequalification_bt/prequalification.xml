<root BTCPP_format="4">

    <BehaviorTree ID="PreQualification_Task">
        <Sequence>
            <!-- 1. System Check -->
            <Condition ID="AllSystemsOK" name="all_systems_check"/>

            <!-- 2. Dive to operating depth (positive-down, metres) -->
            <Action ID="DiveToDepth" name="dive_to_depth"
                    target_depth="1.5"/>

            <!-- 3. Spin until the gate is in view, then stop facing it (depth held). -->
            <Action ID="Do360Turn" name="search_for_gate"
                    success_when_seen="GATE"/>

            <!-- 4. Lock yaw onto the gate, surge in, then commit through. -->
            <Action ID="GoThroughObject" name="go_through_gate"
                    object="GATE"/>

            <!-- 5. After the gate, lock onto the pole and approach until within 1 m. -->
            <Action ID="ApproachObject" name="approach_pole"
                    object="POLE"
                    stop_distance="1.0"
                    delta_d="1.0"
                    timeout="20.0"/>

            <!-- 6. Sit at the pole and hold depth so the AUV doesn't drift up. -->
            <Action ID="HoldPosition" name="hold_at_pole"
                    duration="-1.0"/>

        </Sequence>
    </BehaviorTree>

</root>
